# Local docker-compose environment for development on your machine.
# Copy to .env for local work. These values are intentionally safe demo defaults,
# not production secrets.

DOCKERHUB_USERNAME=local
IMAGE_TAG=demo

APP_JWT_SECRET=dev-jwt-secret-local-only-32-bytes-minimum-value
APP_JWT_EXPIRATION_SECONDS=3600
APP_COOKIE_SECURE=false

DEMO_JWT=

APP_DEMO_USER_EMAIL=admin@example.com
APP_DEMO_USER_PASSWORD=dev-password-local-only

SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/devops_demo
SPRING_DATASOURCE_USERNAME=devops_app
SPRING_DATASOURCE_PASSWORD=devops-app-local-pass
# Local development convenience only. Keep validate in shared/cloud environments.
SPRING_JPA_HIBERNATE_DDL_AUTO=update

AUDIT_URL=http://audit-service:8084/audit/events
AUDIT_API_KEY=dev-audit-key-local
AUDIT_TIMEOUT_MS=2000

MAILER_URL=http://mailer-service:8083/send
MAILER_API_KEY=dev-mailer-key-local
MAILER_TIMEOUT_MS=5000

NOTIFY_URL=http://notification-service:8090/notify
NOTIFY_API_KEY=dev-notify-key-local
NOTIFY_TIMEOUT_MS=3000
NOTIFY_LOG_LEVEL=INFO

TWILIO_ACCOUNT_SID=local-twilio-sid
TWILIO_AUTH_TOKEN=local-twilio-token
TWILIO_FROM_NUMBER=+10000000000
TWILIO_TIMEOUT_MS=5000
TWILIO_STATUS_CALLBACK_URL=http://127.0.0.1:8085/notify/twilio/status

SPRING_MAIL_HOST=mailpit
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=mailpit
SPRING_MAIL_PASSWORD=mailpit
SPRING_MAIL_PROTOCOL=smtp
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=false
SPRING_MAIL_PROPERTIES_MAIL_SMTP_SSL_ENABLE=false
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false
SPRING_MAIL_PROPERTIES_MAIL_SMTP_DEBUG=false
SPRING_MAIL_FROM=no-reply@local.test

MYSQL_ROOT_PASSWORD=mysql-root-local-pass
MYSQL_DATABASE=devops_demo

SPRING_GATEWAY_BIND_HOST=127.0.0.1
SPRING_FRONTEND_PORT=8085
