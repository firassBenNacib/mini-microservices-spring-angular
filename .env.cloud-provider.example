# Runtime/deploy environment reference for a cloud provider.
# Do not use this file directly as a checked-in secret store.

DOCKERHUB_USERNAME=placeholder-username
IMAGE_TAG=demo

APP_JWT_SECRET=replace-with-strong-jwt-secret
APP_JWT_EXPIRATION_SECONDS=3600
APP_COOKIE_SECURE=true
APP_COOKIE_DOMAIN=microservices.example.com

DEMO_JWT=

APP_DEMO_USER_EMAIL=admin@example.com
APP_DEMO_USER_PASSWORD=replace-with-strong-demo-password

SPRING_DATASOURCE_URL=jdbc:mysql://replace-with-database-endpoint:3306/devops_demo
SPRING_DATASOURCE_USERNAME=devops_app
SPRING_DATASOURCE_PASSWORD=replace-with-strong-mysql-app-password
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

AUDIT_URL=http://audit-service:8084/audit/events
AUDIT_API_KEY=replace-with-strong-audit-key
AUDIT_TIMEOUT_MS=2000

MAILER_URL=http://mailer-service:8083/send
MAILER_API_KEY=replace-with-strong-mailer-key
MAILER_TIMEOUT_MS=5000

NOTIFY_URL=http://notification-service:8090/notify
NOTIFY_API_KEY=replace-with-strong-notify-key
NOTIFY_TIMEOUT_MS=3000
NOTIFY_LOG_LEVEL=INFO

TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_FROM_NUMBER=replace-with-twilio-from-number
TWILIO_TIMEOUT_MS=5000
TWILIO_STATUS_CALLBACK_URL=https://microservices.example.com/notify/twilio/status

SPRING_MAIL_HOST=replace-with-smtp-host
SPRING_MAIL_PORT=465
SPRING_MAIL_USERNAME=replace-with-smtp-username
SPRING_MAIL_PASSWORD=replace-with-smtp-password
SPRING_MAIL_PROTOCOL=smtps
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_SSL_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false
SPRING_MAIL_PROPERTIES_MAIL_SMTP_DEBUG=false
SPRING_MAIL_FROM=replace-with-smtp-from-address

MYSQL_ROOT_PASSWORD=replace-with-strong-mysql-root-password
MYSQL_DATABASE=devops_demo

SPRING_GATEWAY_BIND_HOST=0.0.0.0
SPRING_FRONTEND_PORT=8080
FRONTEND_PUBLIC_API_BASE_URL=https://api.example.com
